{
  "name": "jovaltus",
  "displayName": "Jovaltus",
  "description": "AI coding agent with multi-layer quality pipeline",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onView:jovaltus.chatPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jovaltus",
          "title": "Jovaltus",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "jovaltus": [
        {
          "id": "jovaltus.chatPanel",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Jovaltus",
      "properties": {
        "jovaltus.coordinatorModel.modelId": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "description": "Model ID for coordinator agents (planning, reviewing, verifying)"
        },
        "jovaltus.coordinatorModel.contextWindow": {
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "description": "Context window size. Use 'auto' for automatic discovery or set a number."
        },
        "jovaltus.coordinatorModel.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum output tokens for coordinator model"
        },
        "jovaltus.workerModel.modelId": {
          "type": "string",
          "default": "claude-haiku-4-5",
          "description": "Model ID for worker agents (implementation, fixing, simplifying)"
        },
        "jovaltus.workerModel.contextWindow": {
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "description": "Context window size. Use 'auto' for automatic discovery or set a number."
        },
        "jovaltus.workerModel.maxTokens": {
          "type": "number",
          "default": 4096,
          "description": "Maximum output tokens for worker model"
        },
        "jovaltus.openai.baseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for OpenAI-compatible API endpoint"
        },
        "jovaltus.openai.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for OpenAI-compatible API"
        },
        "jovaltus.anthropic.baseUrl": {
          "type": "string",
          "default": "https://api.anthropic.com",
          "description": "Base URL for Anthropic-compatible API endpoint"
        },
        "jovaltus.anthropic.apiKey": {
          "type": "string",
          "default": "",
          "description": "API key for Anthropic-compatible API"
        }
      }
    }
  },
  "scripts": {
    "build": "tsc -b && vite build",
    "build:webview": "vite build",
    "watch": "tsc -b -w",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-markdown": "^0.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@jovaltus/core": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.95.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vscode/vsce": "^3.0.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.0"
  }
}
