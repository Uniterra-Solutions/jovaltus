{
  "name": "jovaltus",
  "displayName": "Jovaltus",
  "description": "AI coding agent with multi-layer quality pipeline",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "vscode": "^1.95.0"
  },
  "activationEvents": [
    "onView:jovaltus.chatPanel"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "jovaltus",
          "title": "Jovaltus",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "views": {
      "jovaltus": [
        {
          "id": "jovaltus.chatPanel",
          "name": "Chat",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Jovaltus",
      "properties": {
        "jovaltus.provider": {
          "type": "string",
          "enum": [
            "anthropic",
            "openai"
          ],
          "enumDescriptions": [
            "Anthropic-compatible API",
            "OpenAI-compatible API"
          ],
          "default": "anthropic",
          "order": 1,
          "description": "API provider for model access"
        },
        "jovaltus.baseUrl": {
          "type": "string",
          "default": "",
          "order": 2,
          "description": "Base URL for the selected provider's API. Leave empty to use the default endpoint (OpenAI: https://api.openai.com/v1, Anthropic: https://api.anthropic.com)."
        },
        "jovaltus.apiKey": {
          "type": "string",
          "default": "",
          "order": 3,
          "description": "API key for the selected provider. Stored securely in SecretStorage."
        },
        "jovaltus.coordinatorModel.modelId": {
          "type": "string",
          "default": "claude-sonnet-4-5",
          "order": 4,
          "description": "Model ID for coordinator agents (planning, reviewing, verifying)"
        },
        "jovaltus.coordinatorModel.contextWindow": {
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "order": 5,
          "description": "Context window size. Use 'auto' for automatic discovery or set a number."
        },
        "jovaltus.coordinatorModel.maxTokens": {
          "type": "number",
          "default": 4096,
          "order": 6,
          "description": "Maximum output tokens for coordinator model"
        },
        "jovaltus.workerModel.modelId": {
          "type": "string",
          "default": "claude-haiku-4-5",
          "order": 7,
          "description": "Model ID for worker agents (implementation, fixing, simplifying)"
        },
        "jovaltus.workerModel.contextWindow": {
          "type": [
            "number",
            "string"
          ],
          "default": "auto",
          "order": 8,
          "description": "Context window size. Use 'auto' for automatic discovery or set a number."
        },
        "jovaltus.workerModel.maxTokens": {
          "type": "number",
          "default": 4096,
          "order": 9,
          "description": "Maximum output tokens for worker model"
        }
      }
    }
  },
  "scripts": {
    "build": "node build.mjs && vite build",
    "build:bundle": "node build.mjs",
    "build:webview": "vite build",
    "watch": "tsc -b -w",
    "package": "vsce package --no-dependencies"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.14.0",
    "@assistant-ui/react-markdown": "^0.14.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@jovaltus/core": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.95.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.0"
  }
}
