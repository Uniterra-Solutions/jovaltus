{
  "name": "jovaltus",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -b && pnpm --filter ./packages/extension run build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "package": "pnpm run build && pnpm --filter ./packages/extension run package",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.34.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.34.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.46.0",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings 0 --no-warn-ignored"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
